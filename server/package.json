{
  "name": "moonplayer-server",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "cli": "tsx src/cli.ts",
    "pkg": "pkg . --targets node18-win-x64 --output ../windows/build/moonplayer-server.exe"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "fastify": "^5.2.0",
    "music-metadata": "^8.1.4",
    "pinyin-pro": "^3.28.1",
    "sql.js": "^1.14.1",
    "webdav": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/sql.js": "^1.4.11",
    "@yao-pkg/pkg": "^6.18.1",
    "esbuild": "^0.28.0",
    "nexe": "^5.0.0-beta.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "bin": "dist/index.js",
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "../windows/build",
    "assets": [
      "node_modules/sql.js/dist/sql-wasm.wasm",
      "node_modules/sql.js/dist/sql-wasm.js",
      "../web/dist/**/*"
    ],
    "scripts": [
      "dist/**/*.js"
    ]
  }
}
