{
  "apps": [
    {
      "name": "moonplayer-server",
      "script": "dist/index.js",
      "cwd": "/home/moon/ai/moonPlayer/server",
      "env": {
        "NODE_ENV": "production",
        "PORT": "3000"
      },
      "watch": false,
      "autorestart": true,
      "max_restarts": 10,
      "restart_delay": 3000,
      "error_file": "/home/moon/.moonplayer/logs/error.log",
      "out_file": "/home/moon/.moonplayer/logs/out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss"
    }
  ]
}